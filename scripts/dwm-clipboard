#!/bin/bash
# ─────────────────────────────────────────────────────────
# dwm-clipboard — clipboard history picker (rofi + clipmenu)
# Reads the active dwm theme from themes.toml so rofi
# always matches the rest of the desktop.
#
# Usage:
#   dwm-clipboard          open clipboard history
#   dwm-clipboard clear    clear entire clipboard history
# ─────────────────────────────────────────────────────────

set -euo pipefail

# ── Theme loader ──────────────────────────────────────────
THEMES_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dwm-titus/themes.toml"

# Defaults — gruvbox-hard (matches the project's active theme)
BG="#282828"
FG="#EBDBB2"
BGSEL="#3C3836"
ACCENT="#FABD2F"
GREY="#928374"

toml_get() {
    local section="$1" key="$2" file="$3"
    awk -v sec="[$section]" -v key="$key" '
        /^\[/ { in_sec = ($0 == sec) }
        in_sec && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
            sub(/^[^=]*=[[:space:]]*/, "")
            gsub(/"/, "")
            gsub(/[[:space:]]+#.*$/, "")
            sub(/[[:space:]]+$/, "")
            print; exit
        }
    ' "$file"
}

load_theme() {
    [[ -f "$THEMES_FILE" ]] || return 1

    local name sec
    name="$(toml_get "active" "theme" "$THEMES_FILE")"
    [[ -n "$name" ]] || return 1

    sec="theme.$name"
    t() { toml_get "$sec" "$1" "$THEMES_FILE"; }

    local v
    v="$(t term_bg)"        && BG="$v"
    v="$(t term_fg)"        && FG="$v"
    v="$(t normbgcolor)"    && BGSEL="$v"
    v="$(t selbordercolor)" && ACCENT="$v"
    v="$(t normfgcolor)"    && GREY="$v"
}

load_theme 2>/dev/null || true

# ── Handle clear subcommand ───────────────────────────────
case "${1:-}" in
    clear|--clear|-c)
        if command -v clipdel &>/dev/null; then
            clipdel --all
            echo "Clipboard history cleared."
        else
            echo "clipdel not found — install clipmenu." >&2
            exit 1
        fi
        exit 0
        ;;
esac

# ── Ensure clipmenud is running ───────────────────────────
# clipmenud is a bash script — pgrep -x won't match it because
# the process name is "bash", not "clipmenud". Use -f instead.
if ! pgrep -f '[c]lipmenud' &>/dev/null; then
    if command -v clipmenud &>/dev/null; then
        clipmenud &
        sleep 0.3
    else
        echo "clipmenud not found — install clipmenu." >&2
        exit 1
    fi
fi

# ── Write a temporary rofi theme ──────────────────────────
# clipmenu invokes: rofi -dmenu -l N <user-args>
# rofi reads its theme from $XDG_CONFIG_HOME/rofi/config.rasi,
# but we override with a temp theme file via -theme.
THEME_TMP="$(mktemp /tmp/dwm-clipboard-XXXXXX.rasi)"
trap 'rm -f "$THEME_TMP"' EXIT

cat > "$THEME_TMP" <<EOF
* {
    background:    ${BG};
    foreground:    ${FG};
    bg-selected:   ${BGSEL};
    accent:        ${ACCENT};
    grey:          ${GREY};
    spacing: 0;
    width: 30em;
}

window {
    background-color: @background;
    border: 0;
    padding: 0;
    location: northwest;
    anchor: northwest;
    x-offset: 0;
    y-offset: 0;
}

mainbox {
    background-color: @background;
    children: [ inputbar, listview ];
}

inputbar {
    background-color: @bg-selected;
    padding: 8px 12px;
}

prompt {
    background-color: @bg-selected;
    text-color: @accent;
    font: "MesloLGS NF Bold 14";
}

entry {
    background-color: @bg-selected;
    text-color: @foreground;
    placeholder: "Search clipboard...";
    placeholder-color: @grey;
    font: "MesloLGS NF 14";
}

listview {
    background-color: @background;
    lines: 12;
    fixed-height: true;
}

element {
    padding: 8px 12px;
    background-color: @background;
    text-color: @foreground;
    font: "MesloLGS NF 13";
}

element selected {
    background-color: @bg-selected;
    text-color: @accent;
}

element-text {
    background-color: inherit;
    text-color: inherit;
}
EOF

# ── Launch clipmenu through rofi with themed override ─────
export CM_LAUNCHER=rofi
export CM_HISTLENGTH=12

exec clipmenu -theme "$THEME_TMP"
